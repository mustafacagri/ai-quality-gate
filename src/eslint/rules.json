{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Phase 1 Rules - Uses plugin recommended configs + custom overrides. Goal: Make Phase 1 so strong that Phase 2 (SonarQube) is optional",
  "_strategy": {
    "sonarjs": "sonarjs.configs.recommended (~200 rules) + sonarjsOverrides",
    "unicorn": "unicorn.configs.recommended (~130 rules) + unicornOverrides",
    "import": "importPlugin.configs.recommended (~46 rules)",
    "promise": "promisePlugin.configs.recommended (~17 rules)",
    "n": "nPlugin.configs.recommended (~41 rules)",
    "regexp": "regexpPlugin.configs.recommended (~82 rules)",
    "typescript": "@typescript-eslint recommended + custom rules (~100 rules)"
  },
  "limits": {
    "file": {
      "maxLinesWarn": 400,
      "maxLinesError": 500,
      "maxFunctions": 15,
      "maxImports": 20
    },
    "function": {
      "maxLinesWarn": 50,
      "maxLinesError": 75,
      "maxStatementsWarn": 20,
      "maxStatementsError": 30,
      "maxParameters": 5,
      "maxNestingDepth": 4,
      "cognitiveComplexity": 15,
      "maxNestedCallbacks": 3,
      "cyclomaticComplexity": 10
    },
    "duplication": {
      "maxDuplicateString": 2
    },
    "magicValues": {
      "_comment": "Magic string/number detection",
      "noMagicNumbers": true,
      "noLiteralStrings": "jsx-text-only"
    }
  },
  "qualityGate": {
    "maxWarningsAllowed": 0,
    "warningsCreateTechDebtIssue": true,
    "errorsBlockDeploy": true
  },
  "sonarjsOverrides": {
    "_comment": "Overrides on top of sonarjs.configs.recommended (266 rules)",
    "cognitive-complexity": ["error", 15],
    "no-duplicate-string": ["error", { "threshold": 3 }],
    "max-switch-cases": ["error", 30],
    "todo-tag": "warn",
    "fixme-tag": "warn",
    "no-commented-code": "warn",
    "deprecation": "warn",
    "no-hardcoded-ip": "warn",
    "no-skipped-tests": "warn"
  },
  "unicornOverrides": {
    "_comment": "Overrides on top of unicorn.configs['flat/recommended'] (143 rules)",
    "prevent-abbreviations": "off",
    "no-null": "off",
    "filename-case": "off",
    "no-array-for-each": "error",
    "no-nested-ternary": "error",
    "no-for-loop": "warn",
    "prefer-ternary": "warn",
    "no-negated-condition": "warn",
    "numeric-separators-style": "warn",
    "prefer-switch": ["warn", { "minimumCases": 3 }],
    "better-regex": "off",
    "_better-regex-reason": "Disabled: conflicts with regexp/strict which is more comprehensive (82 rules vs 1)",
    "prefer-at": "warn",
    "prefer-single-call": "warn",
    "prefer-string-raw": "warn",
    "template-indent": "warn"
  },
  "eslintStrict": {
    "_comment_v2_1_core_fixable": "v2.1.0: no-var, eqeqeq, prefer-const — enforced here; fixes via ESLint --fix only (no duplicate AST fixers).",
    "_comment_import_alias": "Import alias restriction: no-restricted-syntax rule prevents 'import { foo as bar }' pattern. Use original function names or rename local functions instead.",
    "max-lines": ["warn", { "max": 400, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": ["warn", { "max": 50, "skipBlankLines": true, "skipComments": true }],
    "max-statements": ["warn", 20],
    "max-params": ["error", 5],
    "max-depth": ["error", 4],
    "max-nested-callbacks": ["error", 3],
    "complexity": ["error", 10],
    "no-nested-ternary": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-return-await": "error",
    "prefer-promise-reject-errors": "error",
    "require-await": "error",
    "no-async-promise-executor": "error",
    "no-promise-executor-return": "error",
    "no-constructor-return": "error",
    "no-duplicate-imports": "error",
    "no-self-compare": "error",
    "no-template-curly-in-string": "error",
    "no-unmodified-loop-condition": "error",
    "no-unreachable-loop": "error",
    "no-unused-private-class-members": "error",
    "default-case-last": "error",
    "default-param-last": "error",
    "eqeqeq": ["error", "always"],
    "grouped-accessor-pairs": "error",
    "no-caller": "error",
    "no-extend-native": "error",
    "no-extra-bind": "error",
    "no-floating-decimal": "error",
    "no-lone-blocks": "error",
    "no-multi-str": "error",
    "no-new-wrappers": "error",
    "no-octal-escape": "error",
    "no-proto": "error",
    "no-return-assign": "error",
    "no-sequences": "error",
    "no-throw-literal": "error",
    "no-useless-call": "error",
    "no-useless-concat": "error",
    "no-useless-return": "error",
    "prefer-regex-literals": "error",
    "yoda": "error",
    "no-var": "error",
    "prefer-const": "error",
    "object-shorthand": "error",
    "arrow-body-style": ["error", "as-needed"],
    "dot-notation": "error",
    "no-else-return": "error",
    "prefer-template": "error",
    "curly": ["error", "multi-line"],
    "no-extra-boolean-cast": "error",
    "no-unneeded-ternary": "error",
    "prefer-spread": "error",
    "prefer-object-spread": "error",
    "prefer-exponentiation-operator": "error",
    "operator-assignment": "error",
    "logical-assignment-operators": "error",
    "no-empty": "error",
    "no-empty-function": ["error", { "allow": ["arrowFunctions"] }],
    "guard-for-in": "error",
    "radix": "error",
    "no-implicit-coercion": "error",
    "no-param-reassign": ["error", { "props": false }],
    "no-shadow": "off",
    "consistent-return": "error",
    "no-debugger": "error",
    "no-alert": "error",
    "symbol-description": "error",
    "prefer-destructuring": ["warn", { "array": false, "object": true }],
    "no-array-constructor": "error",
    "no-object-constructor": "error",
    "comma-dangle": ["error", "never"],
    "prefer-arrow-callback": ["error", { "allowNamedFunctions": false }],
    "padding-line-between-statements": [
      "error",
      { "blankLine": "always", "prev": "*", "next": ["if", "for", "while", "switch", "try", "with"] },
      { "blankLine": "always", "prev": ["if", "for", "while", "switch", "try", "with"], "next": "*" },
      { "blankLine": "any", "prev": "if", "next": "if" },
      { "blankLine": "any", "prev": "for", "next": "for" },
      { "blankLine": "any", "prev": "while", "next": "while" },
      { "blankLine": "always", "prev": "*", "next": "return" },
      { "blankLine": "always", "prev": "block-like", "next": "*" }
    ]
  },
  "typescriptTypeAware": {
    "no-unnecessary-type-assertion": "error",
    "no-base-to-string": "error",
    "no-non-null-assertion": "error",
    "restrict-template-expressions": [
      "error",
      {
        "allowNumber": true,
        "allowBoolean": true,
        "allowNullish": false,
        "allowAny": false
      }
    ],
    "prefer-optional-chain": "error",
    "prefer-nullish-coalescing": ["error", { "ignorePrimitives": true }],
    "consistent-type-imports": ["error", { "prefer": "type-imports", "fixStyle": "inline-type-imports" }],
    "consistent-type-exports": ["error", { "fixMixedExportsWithInlineTypeSpecifier": true }],
    "no-redundant-type-constituents": "error",
    "no-unnecessary-boolean-literal-compare": "error",
    "no-unnecessary-condition": "warn",
    "no-unnecessary-type-arguments": "error",
    "prefer-includes": "error",
    "prefer-string-starts-ends-with": "error",
    "prefer-reduce-type-parameter": "error",
    "prefer-return-this-type": "error",
    "no-confusing-void-expression": ["error", { "ignoreArrowShorthand": true }],
    "no-meaningless-void-operator": "error",
    "no-mixed-enums": "error",
    "no-unnecessary-template-expression": "error",
    "use-unknown-in-catch-callback-variable": "error",
    "no-unnecessary-qualifier": "error",
    "non-nullable-type-assertion-style": "error",
    "prefer-readonly": "warn",
    "prefer-regexp-exec": "error",
    "return-await": ["error", "in-try-catch"],
    "sort-type-constituents": "warn"
  },
  "typescript": {
    "no-magic-numbers": [
      "warn",
      {
        "ignore": [-1, 0, 1, 2, 10, 100, 1000],
        "ignoreArrayIndexes": true,
        "ignoreDefaultValues": true,
        "ignoreEnums": true,
        "ignoreNumericLiteralTypes": true,
        "ignoreReadonlyClassProperties": true,
        "ignoreTypeIndexes": true
      }
    ],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "array-type": ["error", { "default": "array" }],
    "no-inferrable-types": "error",
    "prefer-as-const": "error",
    "no-shadow": "error",
    "no-empty-function": ["error", { "allow": ["arrowFunctions"] }],
    "no-useless-constructor": "error",
    "no-array-delete": "error",
    "no-duplicate-enum-values": "error",
    "no-duplicate-type-constituents": "error",
    "no-extraneous-class": "error",
    "no-invalid-void-type": "error",
    "no-useless-empty-export": "error",
    "prefer-function-type": "error",
    "prefer-for-of": "error",
    "unified-signatures": "error",
    "ban-tslint-comment": "error",
    "consistent-generic-constructors": ["error", "constructor"],
    "consistent-indexed-object-style": ["error", "record"],
    "consistent-type-definitions": ["error", "interface"],
    "method-signature-style": ["error", "property"],
    "no-empty-interface": "error",
    "no-extra-non-null-assertion": "error",
    "no-import-type-side-effects": "error",
    "no-wrapper-object-types": "error",
    "prefer-namespace-keyword": "error",
    "prefer-ts-expect-error": "error"
  }
}
